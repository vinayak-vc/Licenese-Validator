{
  "info": {
    "name": "Trial Licensing System",
    "_postman_id": "8f7a3f2d-2f6b-4fc8-b5e5-4f9a7cc6f6c1",
    "description": "Postman collection for project-scoped Start Trial and Verify Trial APIs.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "1) Start Trial",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"projectApiKey\": \"{{projectApiKey}}\",\n  \"deviceId\": \"{{deviceId}}\",\n  \"systemInfo\": {\n    \"os\": \"{{os}}\",\n    \"cpu\": \"{{cpu}}\",\n    \"gpu\": \"{{gpu}}\"\n  }\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/startTrial",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "startTrial"
          ]
        },
        "description": "Starts a new trial for a device inside the project resolved from projectApiKey."
      },
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const currentDevice = pm.collectionVariables.get('deviceId');",
              "if (!currentDevice) {",
              "  const generated = `device-${Date.now()}-${Math.floor(Math.random() * 10000)}`;",
              "  pm.collectionVariables.set('deviceId', generated);",
              "}"
            ]
          }
        },
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status is 200 or 409', function () {",
              "  pm.expect([200, 409]).to.include(pm.response.code);",
              "});",
              "",
              "const json = pm.response.json();",
              "if (pm.response.code === 200) {",
              "  pm.collectionVariables.set('token', json.token);",
              "  pm.test('Token exists', function () {",
              "    pm.expect(json.token).to.be.a('string').and.not.empty;",
              "  });",
              "  pm.test('statusCode is 1000', function () {",
              "    pm.expect(json.statusCode).to.eql('1000');",
              "  });",
              "} else {",
              "  pm.test('Trial already used response', function () {",
              "    pm.expect(json.statusCode).to.eql('4009');",
              "    pm.expect(json.error).to.eql('TRIAL_ALREADY_USED');",
              "  });",
              "}"
            ]
          }
        }
      ]
    },
    {
      "name": "2) Verify Trial",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"projectApiKey\": \"{{projectApiKey}}\",\n  \"token\": \"{{token}}\",\n  \"deviceId\": \"{{deviceId}}\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/verifyTrial",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "verifyTrial"
          ]
        },
        "description": "Verifies project-scoped token/device validity against server state."
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status is 200', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "const json = pm.response.json();",
              "pm.test('Response uses standard contract', function () {",
              "  pm.expect(json).to.have.property('message');",
              "  pm.expect(json).to.have.property('token');",
              "  pm.expect(json).to.have.property('statusCode');",
              "  pm.expect(json).to.have.property('error');",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "3) Verify Trial (First Run - No Token)",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"projectApiKey\": \"{{projectApiKey}}\",\n  \"token\": \"\",\n  \"deviceId\": \"{{deviceId}}\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/verifyTrial",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "verifyTrial"
          ]
        }
      }
    },
    {
      "name": "4) Verify Trial (Invalid Token Demo)",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"projectApiKey\": \"{{projectApiKey}}\",\n  \"token\": \"invalid.token.value\",\n  \"deviceId\": \"{{deviceId}}\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/verifyTrial",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "verifyTrial"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status is 200 with invalid token code', function () {",
              "  pm.response.to.have.status(200);",
              "  const json = pm.response.json();",
              "  pm.expect(json.statusCode).to.eql('7001');",
              "  pm.expect(json.error).to.eql('INVALID_TOKEN');",
              "});"
            ]
          }
        }
      ]
    }
  ],
  "variable": [
    {
      "key": "baseUrl",
      "value": "https://us-central1-YOUR_PROJECT_ID.cloudfunctions.net"
    },
    {
      "key": "projectApiKey",
      "value": "REPLACE_PROJECT_API_KEY"
    },
    {
      "key": "deviceId",
      "value": ""
    },
    {
      "key": "token",
      "value": ""
    },
    {
      "key": "os",
      "value": "Windows 11"
    },
    {
      "key": "cpu",
      "value": "Intel(R) Core(TM) i7"
    },
    {
      "key": "gpu",
      "value": "NVIDIA RTX 3060"
    }
  ]
}
